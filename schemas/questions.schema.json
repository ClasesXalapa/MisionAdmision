{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://misionadmision.example/schemas/questions.schema.json",
  "title": "Banco global de preguntas",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version", "generated_at", "preguntas"],
  "properties": {
    "schema_version": {"const": 1},
    "version": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,100}$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "preguntas": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "enunciado",
          "imagen_url",
          "opciones",
          "respuesta_correcta",
          "categoria",
          "etiquetas",
          "dificultad"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "enunciado": {"type": "string", "minLength": 1},
          "imagen_url": {
            "oneOf": [
              {"type": "null"},
              {"type": "string", "format": "uri", "pattern": "^https://"}
            ]
          },
          "opciones": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {"type": "string", "minLength": 1}
          },
          "respuesta_correcta": {"enum": ["A", "B", "C", "D"]},
          "categoria": {"type": "string", "minLength": 1},
          "etiquetas": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "dificultad": {"enum": ["basico", "intermedio", "avanzado"]}
        }
      }
    }
  }
}
