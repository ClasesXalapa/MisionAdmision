{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://misionadmision.example/schemas/progress_backup.schema.json",
  "title": "Misión Admisión Progress Backup",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schema_version",
    "app_version",
    "exported_at",
    "data"
  ],
  "properties": {
    "format": {
      "const": "mision_admision_progress_backup"
    },
    "schema_version": {
      "const": 1
    },
    "app_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50
    },
    "exported_at": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "learner_progress",
        "daily_attempt",
        "resource_tracking"
      ],
      "properties": {
        "learner_progress": {
          "$ref": "#/$defs/learnerProgress"
        },
        "daily_attempt": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/dailyAttempt"}
          ]
        },
        "resource_tracking": {
          "$ref": "#/$defs/resourceTracking"
        }
      }
    }
  },
  "$defs": {
    "dateKey": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "learnerProgress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_streak",
        "best_streak",
        "shields",
        "last_completed_date_key",
        "last_streak_date_key",
        "total_daily_challenges_completed",
        "last_shield_used_date_key",
        "last_shield_use_count"
      ],
      "properties": {
        "current_streak": {"type": "integer", "minimum": 0},
        "best_streak": {"type": "integer", "minimum": 0},
        "shields": {"type": "integer", "minimum": 0, "maximum": 3},
        "last_completed_date_key": {"$ref": "#/$defs/dateKey"},
        "last_streak_date_key": {"$ref": "#/$defs/dateKey"},
        "total_daily_challenges_completed": {
          "type": "integer",
          "minimum": 0
        },
        "last_shield_used_date_key": {"$ref": "#/$defs/dateKey"},
        "last_shield_use_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        }
      }
    },
    "dailyAttempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "challenge_id",
        "date_key",
        "title",
        "kind",
        "question_ids",
        "answers",
        "current_index",
        "started_at"
      ],
      "properties": {
        "challenge_id": {"type": "string", "minLength": 1},
        "date_key": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "title": {"type": "string", "minLength": 1},
        "kind": {
          "enum": ["DAILY_SCHEDULED", "DAILY_RANDOM_FALLBACK"]
        },
        "question_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "answers": {
          "type": "object",
          "additionalProperties": {
            "enum": ["A", "B", "C", "D"]
          }
        },
        "current_index": {"type": "integer", "minimum": 0},
        "started_at": {"type": "string", "format": "date-time"}
      }
    },
    "resourceTracking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["viewed_ids", "completed_ids"],
      "properties": {
        "viewed_ids": {
          "type": "array",
          "maxItems": 10000,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 200}
        },
        "completed_ids": {
          "type": "array",
          "maxItems": 10000,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 200}
        }
      }
    }
  }
}
